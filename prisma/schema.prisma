generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── better-auth tables ──────────────────────────────────────────────────────

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  profile       UserProfile?
}

model Session {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                    String    @id
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ── Application tables ──────────────────────────────────────────────────────

model UserProfile {
  id               String   @id // Matches better-auth User.id
  user             User     @relation(fields: [id], references: [id], onDelete: Cascade)
  discordId        String?  @unique
  robloxId         String?  @unique
  linearId         String?  @unique
  linearEmail      String?  @unique
  legalName        String?
  shippingAddress  String?  // For merch

  // Roles and Permissions
  role             Role     @default(DEVELOPER)

  // Payment Preferences
  paymentMethod    PaymentMethod @default(PAYPAL)
  paypalEmail      String?
  duitNowId        String?
  bankName         String?
  bankAccountNumber String?
  bankAccountName  String?
  robuxUsername    String?

  // Relationships
  transactions     Transaction[]
  invites          Invite[]
  signedDocuments  SignedDocument[]
}

model Invite {
  id               String   @id @default(cuid())
  token            String   @unique
  creatorId        String
  creator          UserProfile @relation(fields: [creatorId], references: [id])
  used             Boolean  @default(false)
  usedById         String?
  createdAt        DateTime @default(now())
}

enum Role {
  ADMIN
  DEVELOPER
}

enum PaymentMethod {
  PAYPAL
  DUITNOW
  ROBUX
  BANK_TRANSFER
}

model Transaction {
  id               String   @id @default(cuid())
  userId           String
  user             UserProfile @relation(fields: [userId], references: [id])
  linearIssueId    String?  @unique // To prevent double crediting
  linearIssueIdentifier String? // e.g. "DEV-123"
  linearIssueTitle String?
  linearIssueUrl   String?
  amount           Float
  currency         String   @default("USD") // Or "R$"
  status           TxStatus @default(PENDING) // PENDING, PAID, CANCELLED
  createdAt        DateTime @default(now())
  paidAt           DateTime?
}

enum TxStatus {
  PENDING
  PAID
  CANCELLED
}

enum DocumentType {
  COI
  NDA
}

model SignedDocument {
  id              String       @id @default(cuid())
  userId          String
  user            UserProfile  @relation(fields: [userId], references: [id])
  documentType    DocumentType
  templateVersion String
  templateContent String
  legalName       String
  signedAt        DateTime     @default(now())
  ipAddress       String?

  coiEntries      CoiEntry[]

  @@unique([userId, documentType])
}

model CoiEntry {
  id                  String         @id @default(cuid())
  signedDocumentId    String
  signedDocument      SignedDocument  @relation(fields: [signedDocumentId], references: [id], onDelete: Cascade)
  organizationName    String
  natureOfInvolvement String
  description         String
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}
